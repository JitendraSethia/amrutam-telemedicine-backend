# ─────────────────────────────────────────────────────────────
# Amrutam Telemedicine Backend — environment configuration
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# All secrets are injected via env vars (12-factor). In production
# these come from a secrets manager (AWS Secrets Manager / Vault).
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_NAME=amrutam-telemedicine
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://amrutam:amrutam@localhost:5432/amrutam
PGPOOL_MAX=20
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONN_TIMEOUT_MS=5000
# Optional read-replica connection string for read/write splitting
DATABASE_REPLICA_URL=

# Redis (cache, rate limiting, idempotency, BullMQ)
REDIS_URL=redis://localhost:6379

# JWT / Auth
# Generate strong values: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900          # 15 minutes (seconds)
JWT_REFRESH_TTL=1209600     # 14 days (seconds)
JWT_ISSUER=amrutam.auth
JWT_AUDIENCE=amrutam.api

# Field-level encryption for PII at rest (AES-256-GCM).
# Key ring: comma-separated "kid:base64key" entries. First = active key.
# Generate a key: `openssl rand -base64 32`
DATA_ENCRYPTION_KEYS=v1:0000000000000000000000000000000000000000000=
DATA_ENCRYPTION_ACTIVE_KID=v1

# MFA
MFA_ISSUER=Amrutam Telemedicine

# Rate limiting (per client per window)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=amrutam-telemedicine
METRICS_ENABLED=true
TRACING_ENABLED=true

# Payments (mock gateway)
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret
PAYMENT_PROVIDER_BASE_URL=http://localhost:9099

# Booking policy
SLOT_HOLD_TTL_SECONDS=300   # how long a slot is held awaiting payment
